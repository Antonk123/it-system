# IT-Ticket — exempel-konfiguration
# Kopiera till .env och fyll i värden för din installation.
# Filen ska ALDRIG checkas in i git.
#
# Tips: kör setup.sh så genereras .env automatiskt med rätt värden.

# ─── DET HÄR MÅSTE DU FYLLA I ─────────────────────────────────────────────────

# JWT-hemlighet — generera en stark slumpsträng (öppna terminal: openssl rand -hex 64)
JWT_SECRET=

# CSRF-hemlighet — generera en till slumpsträng (samma kommando)
CSRF_SECRET=

# Admin-konto som skapas vid första start (om det inte redan finns)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_NAME=

# Vilka domäner får anropa API:et? Komma-separerat, inga mellanslag.
# Exempel: https://ticket.foretag.se,https://www.foretag.se
CORS_ORIGIN=

# Bas-URL till installationen (används i mejl med länkar och i password-reset-länkar)
APP_BASE_URL=https://ticket.foretag.se

# Varumärke i utgående mejl (header + footer). Default 'IT-Support' om inte satt.
# Sätt till företagsnamnet för att rebranda hela mail-flödet utan kodändring.
BRAND_NAME=IT-Support

# ─── AI-FUNKTIONER (rekommenderas — gör systemet 10x mer värdefullt) ──────────

# Anthropic API-nyckel — skapa på console.anthropic.com
# Lämna tom för att stänga av AI-funktioner helt (allt övrigt fungerar normalt)
ANTHROPIC_API_KEY=

# (Valfritt) Default-modell — Haiku 4.5 är optimal för IT-helpdesk-användning.
# Snabb (<1s), billig (~$0,001/utkast), bra på svenska, bra på att referera KB.
# AI_MODEL=claude-haiku-4-5-20251001

# (Valfritt) Escape-hatch — uppgradera draft+summary till starkare modell om du
# under pilot upplever att svaren blir för generiska. Kategorisering rörs ej.
# AI_MODEL_SMART=claude-sonnet-4-6

# (Valfritt) Max antal kommentarer som skickas till AI vid ärendesammanfattning.
# Högre = bättre sammanfattningar men dyrare API-anrop. Default: 30.
# AI_MAX_SUMMARY_COMMENTS=30

# (Valfritt) Cirkuit-breaker för månatlig token-användning. Default: 5_000_000.
# AI-anrop avvisas när månadens summa överstiger denna gräns.
# AI_MONTHLY_TOKEN_LIMIT=5000000

# ─── E-POST UT (valfritt men rekommenderat) ───────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ticket@foretag.se
EMAIL_TO=

# ─── E-POST IN (valfritt — skapar ärenden från inkommande mejl) ──────────────

IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_SECURE=true
IMAP_POLL_INTERVAL=60
IMAP_AUTO_CREATE_CONTACT=true

# Basic Auth (vanliga IMAP-servrar):
IMAP_PASS=

# OAuth2 (Microsoft 365 — kräver App Registration i Entra):
# IMAP_TENANT_ID=
# IMAP_CLIENT_ID=
# IMAP_CLIENT_SECRET=

# ─── PUSH-NOTIFIKATIONER (valfritt) ──────────────────────────────────────────
# Generera nycklar med: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@foretag.se

# ─── DET HÄR KAN DU OFTAST STRUNTA I ─────────────────────────────────────────

# Docker-portar (setup.sh sätter dessa)
FRONTEND_PORT=8082
BACKEND_PORT=3002

PORT=3001
NODE_ENV=production
DB_PATH=/app/data/database.sqlite
UPLOAD_DIR=/app/data/uploads

# Auto-stäng lösta ärenden efter X dagar (default: 30)
AUTO_CLOSE_DAYS=30

# Antal dagar att behålla automatiska backup-snapshots (default: 7)
BACKUP_RETENTION_DAYS=7

# Push-notis om ärenden som inte uppdaterats på X dagar (default: 7)
# PUSH_AGING_DAYS=7

# Frontend API URL (default: /api, ändra vid deployment utan reverse proxy)
# VITE_API_URL=/api
